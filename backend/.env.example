# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_USE_NATIVE=true
GEMINI_FLASH_MODEL=google/gemini-2.0-flash
GEMINI_PRO_MODEL=google/gemini-2.0-flash
GOOGLE_WORKSPACE_CREDS=path/to/service_account.json
GOOGLE_ADMIN_EMAIL=admin@yourdomain.com
OAUTH_USE_SYNTHETIC=true
OAUTH_SCAN_INTERVAL_HOURS=6
DISABLE_SCAN_SCHEDULER=false
DASHBOARD_PASSWORD=contextguard2026
